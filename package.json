{
  "name": "cctrace",
  "version": "0.1.1",
  "description": "TLS-intercepting HTTP tracer for Claude Code — captures every API call (messages, OAuth, usage/credits, MCP) with a live categorized web UI",
  "type": "module",
  "bin": {
    "cctrace": "./src/cli.ts"
  },
  "files": [
    "src",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "start": "bun run src/cli.ts",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thevibeworks/cctrace.git"
  },
  "homepage": "https://github.com/thevibeworks/cctrace#readme",
  "bugs": {
    "url": "https://github.com/thevibeworks/cctrace/issues"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "keywords": ["claude", "claude-code", "anthropic", "trace", "proxy", "mitm", "debug", "cli"],
  "license": "MIT"
}
