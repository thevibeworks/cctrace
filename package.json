{
  "name": "@thevibeworks/cctrace",
  "version": "0.21.0",
  "description": "TLS-intercepting HTTP tracer for the Claude Code, Codex, and Grok CLIs — captures every API call (messages, OAuth, usage/credits, MCP) with a live web UI: reconstructed sessions, replay, cost/cache/latency chips. External hosts pass through as byte-counted tunnels, never decrypted.",
  "type": "module",
  "bin": {
    "cctrace": "./src/cli.ts"
  },
  "files": [
    "src",
    "assets",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "start": "bun run src/cli.ts",
    "test": "bun test"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thevibeworks/cctrace.git"
  },
  "homepage": "https://github.com/thevibeworks/cctrace#readme",
  "bugs": {
    "url": "https://github.com/thevibeworks/cctrace/issues"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "parse5": "^8.0.1"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "trace",
    "proxy",
    "mitm",
    "debug",
    "cli",
    "http",
    "tls",
    "inspector"
  ],
  "license": "MIT"
}
